# Server
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000

# Billing mode: "free" (no Shopier) or "paid" (Shopier checkout required)
APP_MODE=free

# Storage — leave MONGODB_URI empty to use local JSON file (data/surprises.json)
MONGODB_URI=

# Product pricing (Shopier uses numeric currency codes: 0=TRY, 1=USD, 2=EUR)
PRODUCT_PRICE=699.90
PRODUCT_CURRENCY=0

# Shopier OSB credentials (from Shopier panel → Entegrasyonlar)
SHOPIER_API_KEY=your_api_key
SHOPIER_API_SECRET=your_api_secret
SHOPIER_WEBSITE_INDEX=1

# Optional buyer defaults when dashboard does not collect email/phone
SHOPIER_DEFAULT_EMAIL=customer@example.com
SHOPIER_DEFAULT_PHONE=5550000000
