# Server
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000

MONGODB_URI=

# ─── Shopier (required) ───

# 1) Ödeme için — Hesap Yönetimi → Kişisel Erişim Anahtarı (PAT)
SHOPIER_PAT=your-personal-access-token

# 2) Mağaza slug — https://www.shopier.com/MAGAZA-ADIN
SHOPIER_SHOP_SLUG=your-shop-slug

# 3) Webhook HMAC secret — Geliştirici → Uygulama → Client Secret
SHOPIER_WEBHOOK_SECRET=your-webhook-secret

# Default currency when omitted in payment request body (optional)
# PRODUCT_CURRENCY=TRY

# Alias used by older config (optional)
# SHOPIER_CLIENT_SECRET=your-client-secret

# Client ID is only needed for OAuth app installs (not required for our server)
# SHOPIER_CLIENT_ID=your-client-id

# Aliases (optional)
# SHOPIER_API_SECRET=
# SHOPIER_WEBHOOK_TOKEN=

# Line items (name, price, id, quantity) are sent dynamically per payment request.
# No SHOPIER_PRODUCT_ID or PRODUCT_PRICE env vars are required.

# Preview QR without payment (optional — for testing)
# ALLOW_DEV_QR=true
# PREVIEW_SECRET=choose-a-long-random-string
