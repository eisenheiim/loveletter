# Server
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000

MONGODB_URI=
PRODUCT_PRICE=699.90

# ─── Shopier (required) ───

# 1) Ödeme için — Hesap Yönetimi → Kişisel Erişim Anahtarı (PAT)
SHOPIER_PAT=your-personal-access-token

# 2) Mağaza slug — https://www.shopier.com/MAGAZA-ADIN
SHOPIER_SHOP_SLUG=your-shop-slug

# 3) Webhook imzası — Geliştirici → Uygulama → Client Secret
SHOPIER_CLIENT_SECRET=your-client-secret

# Client ID is only needed for OAuth app installs (not required for our server)
# SHOPIER_CLIENT_ID=your-client-id

# Aliases (optional)
# SHOPIER_API_SECRET=
# SHOPIER_WEBHOOK_TOKEN=

# Optional. Must end in .jpg or .png. If unset, uses BASE_URL/product-cover.jpg on HTTPS.
# SHOPIER_PRODUCT_IMAGE_URL=https://your-domain.onrender.com/product-cover.jpg
